# --- Server ---
PORT=3000
JWT_SECRET=change_this_to_a_long_random_string

# --- Postgres (Render provides this automatically as DATABASE_URL if you
# attach a Render Postgres instance to this service) ---
DATABASE_URL=postgres://user:password@host:5432/whisper

# --- Deriv API ---
# Get an app_id at https://developers.deriv.com/docs/getting-started (register an application)
# A demo/read-only app_id (1089) works for public tick subscriptions, no login token needed.
DERIV_APP_ID=1089
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3

# --- Telegram ---
# Create a bot with @BotFather on Telegram, copy the token here
TELEGRAM_BOT_TOKEN=123456789:AA...your_bot_token
# Set to true only when you register a public HTTPS webhook (Render gives you one).
# Leave false to use polling, which is simpler for getting started.
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=https://your-service.onrender.com/telegram/webhook

# --- Firebase Cloud Messaging (Android push) ---
# In Firebase console: Project settings -> Service accounts -> Generate new private key
# Paste the ENTIRE downloaded JSON as a single line here.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", "...": "..."}

# --- MT5 EA bridge (for symbols Deriv's WS API doesn't expose, e.g. Volatility 150/250) ---
# Any long random string; the MQL5 EA sends this in an X-Whisper-Secret header.
MT5_BRIDGE_SECRET=change_this_to_a_long_random_string
